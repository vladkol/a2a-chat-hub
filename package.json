{
  "name": "ai-studio-angular-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "cross-env ng serve --port=3000 --host=0.0.0.0 ${DISABLE_HMR:+--live-reload=false}",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "deploy": "bash scripts/deploy.sh",
    "serve:ssr:app": "PORT=${PORT:-8080} node dist/app/server/server.mjs",
    "setup:a2ui": "bash scripts/setup-a2ui.sh",
    "prepare": "npm run setup:a2ui"
  },
  "private": true,
  "dependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "@a2ui/angular": "^0.8.3",
    "@a2ui/web_core": "file:lib/a2ui-web_core.tgz",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.0",
    "@google/genai": "^1.27.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "idb-keyval": "^6.2.2",
    "marked": "^17.0.3",
    "motion": "^12.23.24",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.1",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.17.19",
    "angular-eslint": "21.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.47.0",
    "vitest": "^4.0.0"
  }
